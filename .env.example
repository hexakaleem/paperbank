# Paper Bank — Environment Variables
# Copy this to .env and fill in your values

# Database
DB_NAME=paperbank
DB_USER=postgres
DB_PASSWORD=your-strong-password-here

# Auth
JWT_SECRET=your-random-jwt-secret-at-least-32-chars

# Backend
NODE_ENV=production

# CORS (optional — defaults to * which is fine when Nginx proxies)
# CORS_ORIGIN=http://your-ec2-ip
